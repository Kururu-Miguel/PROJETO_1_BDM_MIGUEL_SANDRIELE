<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_clube"
    app:startDestination="@id/mainActivity">
    <fragment
        android:id="@+id/descFragment"
        android:name="com.example.projeto_1_pdm.viewmodel.DescFragment"
        android:label="fragment_desc"
        tools:layout="@layout/fragment_desc" >
        <action
            android:id="@+id/action_descFragment_to_eventFragment"
            app:destination="@id/eventFragment" />
    </fragment>
    <fragment
        android:id="@+id/eventFragment"
        android:name="com.example.projeto_1_pdm.viewmodel.EventFragment"
        android:label="fragment_event"
        tools:layout="@layout/fragment_event" />
    <activity
        android:id="@+id/mainActivity"
        android:name="com.example.projeto_1_pdm.viewmodel.MainActivity"
        android:label="activity_clube"
        tools:layout="@layout/activity_clube" />
</navigation>